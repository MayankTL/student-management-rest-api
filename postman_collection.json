{
  "info": {
    "name": "Student Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"age\": 20,\n  \"course\": \"Computer Science\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/students",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["students"]
        }
      }
    },
    {
      "name": "Get Students",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:5000/students?page=1&limit=10",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["students"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Get Student By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:5000/students/{{studentId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["students", "{{studentId}}"]
        }
      }
    },
    {
      "name": "Update Student",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"age\": 22,\n  \"course\": \"Software Engineering\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/students/{{studentId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["students", "{{studentId}}"]
        }
      }
    },
    {
      "name": "Delete Student",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:5000/students/{{studentId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["students", "{{studentId}}"]
        }
      }
    }
  ]
}
